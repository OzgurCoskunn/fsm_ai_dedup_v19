<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ai_dedup_log_tree" model="ir.ui.view">
        <field name="name">ai.dedup.log.list</field>
        <field name="model">ai.dedup.log</field>
        <field name="arch" type="xml">
            <list string="AI Dedup Log" default_order="create_date desc">
                <field name="create_date"/>
                <field name="endpoint"/>
                <field name="partner_type"/>
                <field name="parent_id"/>
                <field name="matched_id"/>
                <field name="confidence"/>
                <field name="threshold"/>
                <field name="decision"/>
                <field name="model_used"/>
                <field name="tokens_in"/>
                <field name="tokens_out"/>
                <field name="reason"/>
            </list>
        </field>
    </record>

    <record id="view_ai_dedup_log_form" model="ir.ui.view">
        <field name="name">ai.dedup.log.form</field>
        <field name="model">ai.dedup.log</field>
        <field name="arch" type="xml">
            <form string="AI Dedup Log">
                <sheet>
                    <group>
                        <group>
                            <field name="create_date"/>
                            <field name="endpoint"/>
                            <field name="partner_type"/>
                            <field name="parent_id"/>
                            <field name="matched_id"/>
                        </group>
                        <group>
                            <field name="confidence"/>
                            <field name="threshold"/>
                            <field name="decision"/>
                            <field name="model_used"/>
                            <field name="tokens_in"/>
                            <field name="tokens_out"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Adaylar">
                            <field name="candidate_ids" widget="many2many" readonly="1"/>
                        </page>
                        <page string="Input Payload">
                            <field name="input_payload" widget="text"/>
                        </page>
                        <page string="LLM Raw Response">
                            <field name="raw_response" widget="text"/>
                        </page>
                        <page string="Reason">
                            <field name="reason" widget="text"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ai_dedup_log" model="ir.actions.act_window">
        <field name="name">AI Dedup Loglari</field>
        <field name="res_model">ai.dedup.log</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_ai_dedup_root" name="AI Dedup" sequence="100"/>
    <menuitem id="menu_ai_dedup_log"
              name="Loglar"
              parent="menu_ai_dedup_root"
              action="action_ai_dedup_log"
              sequence="10"/>
</odoo>
