<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ai_dedup_test_wizard_form" model="ir.ui.view">
        <field name="name">ai.dedup.test.wizard.form</field>
        <field name="model">ai.dedup.test.wizard</field>
        <field name="arch" type="xml">
            <form string="AI Dedup Manuel Test">
                <sheet>
                    <group>
                        <group string="Test Verisi">
                            <field name="parent_id"/>
                            <field name="partner_type"/>
                            <field name="test_name"/>
                            <field name="test_street"/>
                            <field name="test_mobile"/>
                            <field name="test_email"/>
                        </group>
                        <group string="Sonuc" invisible="candidates_count == 0">
                            <field name="candidates_count"/>
                            <field name="matched_partner_id"/>
                            <field name="confidence"/>
                            <field name="threshold"/>
                            <field name="model_used"/>
                            <field name="tokens_in"/>
                            <field name="tokens_out"/>
                        </group>
                    </group>
                    <group string="Aciklama" invisible="not reason">
                        <field name="reason" nolabel="1"/>
                    </group>
                    <group string="Adaylar (LLM cagrisinda)" invisible="not candidates_text">
                        <field name="candidates_text" nolabel="1" widget="text"/>
                    </group>
                    <group string="Raw LLM Response" invisible="not raw_response">
                        <field name="raw_response" nolabel="1" widget="text"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_run_match" string="AI ile Eslestir" type="object" class="btn-primary"/>
                    <button special="cancel" string="Kapat"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_ai_dedup_test_wizard" model="ir.actions.act_window">
        <field name="name">AI Dedup Manuel Test</field>
        <field name="res_model">ai.dedup.test.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_ai_dedup_test_v19"
              name="Manuel Test"
              parent="menu_ai_dedup_root"
              action="action_ai_dedup_test_wizard"
              sequence="20"/>
</odoo>
